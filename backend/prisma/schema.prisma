generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(255)
  email           String            @unique(map: "email") @db.VarChar(255)
  created_at      DateTime?         @default(now()) @db.Timestamp(0)
  password        String            @db.VarChar(255)
  role            String            @default("user") @db.VarChar(50)
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  WorkspaceMember WorkspaceMember[]
  Invite Invite[]
  user_id   String?  @unique // Optional external biometric ID (facial recognition)
  face_registered Boolean @default(false)
  attendances Attendance[]
  FaceEmbedding FaceEmbedding[]

  ProductivitySnapshot ProductivitySnapshot[]
}

model Workspace {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(255)
  ownerId         Int
  createdAt       DateTime?         @default(now()) @db.Timestamp(0)
  updatedAt       DateTime?         @default(now()) @db.Timestamp(0)
  owner           users             @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Workspace_ibfk_1")
  WorkspaceMember WorkspaceMember[]
  Invite          Invite[]
  ProductivitySnapshots ProductivitySnapshot[]

  @@index([createdAt], map: "idx_createdAt")
  @@index([ownerId], map: "idx_ownerId")
  Attendance Attendance[]
}

model WorkspaceMember {
  id          Int                  @id @default(autoincrement())
  workspaceId Int
  userId      Int
  role        WorkspaceMember_role @default(user)
  createdAt   DateTime?            @default(now()) @db.Timestamp(0)
  Workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "WorkspaceMember_ibfk_1")
  users       users                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "WorkspaceMember_ibfk_2")

  @@unique([workspaceId, userId], map: "unique_workspace_user")
  @@index([role], map: "idx_role")
  @@index([userId], map: "idx_userId")
  @@index([workspaceId], map: "idx_workspaceId")
}

model Invite {
  id           String     @id @default(uuid())
  email        String
  workspaceId  Int
  role         WorkspaceMember_role @default(user)
  invitedBy    Int
  status       InviteStatus @default(PENDING)
  createdAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  inviter    users     @relation(fields: [invitedBy], references: [id])
}

enum WorkspaceMember_role {
  admin
  user
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Attendance {
  id        String           @id @default(cuid())

  // Standardized relation to users.id
  userId    Int
  user      users            @relation(fields: [userId], references: [id])

  // Attendance is always scoped to a workspace
  workspaceId Int
  workspace   Workspace       @relation(fields: [workspaceId], references: [id])

  check_in   DateTime        @default(now())
  check_out  DateTime?
  confidence Float?          // Recognition confidence score
  status     AttendanceStatus @default(PRESENT)

  // Productivity-related fields
  sessionDuration Float?
  isAfterHours    Boolean     @default(false)
  embeddingDrift  Float?

  location   String?         // Optional: room/location
  device_id  String?         // Optional: camera device
}

model FaceEmbedding {
  id          String   @id @default(cuid())
  // Standardized relation to users.id
  userId      Int
  user        users    @relation(fields: [userId], references: [id])
  qdrant_id   String   @unique // Qdrant internal ID
  created_at  DateTime @default(now())
  is_active   Boolean  @default(true) // For multiple faces per user
}

model ProductivitySnapshot {
  id                String   @id @default(uuid())
  userId            Int
  workspaceId       Int

  attendanceScore   Float
  reliabilityScore  Float
  totalHours        Float
  avgConfidence     Float
  afterHours        Float

  finalScore        Float

  periodType        String   // "daily" | "monthly"
  periodStart       DateTime
  periodEnd         DateTime

  generatedAt       DateTime @default(now())

  user        users      @relation(fields: [userId], references: [id])
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([userId])
  @@index([periodType])
}